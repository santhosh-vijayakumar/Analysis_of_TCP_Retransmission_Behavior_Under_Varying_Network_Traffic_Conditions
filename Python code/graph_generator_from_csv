def graph_01_bif_vs_throughput(df):
    """GRAPH 1: BIF vs Throughput"""
    print("\n📊 Generating GRAPH 1: BIF vs Throughput")
    fig, ax = plt.subplots()
    for condition in ['Normal', 'Medium', 'High']:
        add_condition_scatter(ax, df, 'bytes_in_flight_avg', 'throughput_bps', condition)

    ax.set_xlabel('Bytes In Flight (bytes)')
    ax.set_ylabel('Throughput (bps)')
    ax.set_title('GRAPH 1: BIF vs Throughput\n(Retransmission Root Cause)')
    ax.legend()
    ax.set_xscale('symlog')
    ax.grid(True, alpha=0.3)
    save_fig('01_BIF_vs_Throughput.png')


