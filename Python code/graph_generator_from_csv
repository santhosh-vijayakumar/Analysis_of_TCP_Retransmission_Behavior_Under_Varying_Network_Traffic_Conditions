    if normal_df is None:
        print("\n❌ Failed to load data. Please check file paths.")
        print("\n💡 TIPS:")
        print("   1. Use raw strings: r'D:\\path\\to\\file.csv'")
        print("   2. Or use forward slashes: 'D:/path/to/file.csv'")
        print("   3. Make sure files exist at the specified paths")
        return

    print(f"\n📁 Output directory: {OUTPUT_DIR}")
    print("\n" + "=" * 60)
    print("GENERATING 20 GRAPHS")
    print("=" * 60)

    # Generate all 20 graphs
    graph_01_bif_vs_throughput(all_df)
    graph_02_sack_vs_retransmissions(all_df)
    graph_03_window_vs_throughput(all_df)
