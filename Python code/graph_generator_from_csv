def graph_10_normalized_throughput(df):
    """GRAPH 10: Normalized Throughput (Efficiency) over Time"""
    print("📊 Generating GRAPH 10: Normalized Throughput")
    fig, ax = plt.subplots(figsize=(12, 6))

    for condition in ['Normal', 'Medium', 'High']:
        mask = df['condition'] == condition
        subset = df[mask].copy()

        # Avoid division by zero
        efficiency = np.where(subset['throughput_bps'] > 0,
                              (subset['goodput_bps'] / subset['throughput_bps']) * 100, 0)

        ax.scatter(subset['time_s'], efficiency,
                   alpha=0.5, s=10, label=condition, color=COLORS[condition])

    ax.set_xlabel('Time (seconds)')
    ax.set_ylabel('Efficiency (Goodput/Throughput × 100%)')
    ax.set_title('GRAPH 10: Normalized Throughput Efficiency\n(Retransmission Overhead Visualization)')
    ax.legend()
    ax.set_ylim(0, 105)
    ax.grid(True, alpha=0.3)
    save_fig('10_Normalized_Throughput.png')


def graph_11_sack_efficiency(df):
    """GRAPH 11: SACK Efficiency (Derived Metric)"""
    print("📊 Generating GRAPH 11: SACK Efficiency")
    fig, ax = plt.subplots()

    for condition in ['Normal', 'Medium', 'High']:
        mask = df['condition'] == condition
        subset = df[mask].copy()

        # SACK Efficiency = 1 - (Retrans / (DupACKs/3))
        potential_retrans = subset['dupacks'] / 3
        sack_eff = np.where(potential_retrans > 0,
                            1 - np.clip(subset['retransmissions'] / potential_retrans, 0, 1), 1)

        ax.scatter(subset['time_s'], sack_eff,
                   alpha=0.5, s=10, label=condition, color=COLORS[condition])

    ax.set_xlabel('Time (seconds)')
    ax.set_ylabel('SACK Efficiency')
    ax.set_title('GRAPH 11: SACK Efficiency over Time\n(1 = Perfect, 0 = Complete Failure)')
    ax.legend()
    ax.set_ylim(-0.1, 1.1)
    ax.grid(True, alpha=0.3)
    save_fig('11_SACK_Efficiency.png')


def graph_12_estimated_cwnd_vs_time(df):
    """GRAPH 12: Estimated Congestion Window vs Time"""
    print("📊 Generating GRAPH 12: Estimated Congestion Window")
    fig, ax = plt.subplots(figsize=(12, 6))

    for condition in ['Normal', 'Medium', 'High']:
        mask = df['condition'] == condition
        subset = df[mask].copy()

        # Estimate cwnd (simplified)
        mss = 1460
        # Use goodput as proxy for sending rate
        cwnd_est = np.clip(subset['goodput_bps'] / 8 / mss, 0, 100)

        # Filter outliers for medium traffic (BIF artifacts)
        if condition == 'Medium':
            cwnd_est = np.where(cwnd_est > 100, 0, cwnd_est)

        ax.plot(subset['time_s'], cwnd_est,
                label=condition, color=COLORS[condition], linewidth=1.5, alpha=0.7)

    ax.axhline(y=4, color=COLORS['Threshold'], linestyle='--', alpha=0.7,
               label='Death Spiral Threshold (4 MSS)')
    ax.set_xlabel('Time (seconds)')
    ax.set_ylabel('Estimated Congestion Window (MSS)')
    ax.set_title('GRAPH 12: Estimated Congestion Window vs Time\n(Death Spiral Below 4-6 MSS)')
    ax.legend()
    ax.set_ylim(0, 30)
    ax.grid(True, alpha=0.3)
    save_fig('12_cwnd_vs_Time.png')


def graph_13_inter_retrans_histogram(df):
    """GRAPH 13: Histogram of Inter-Retransmission Times"""
    print("📊 Generating GRAPH 13: Inter-Retransmission Histogram")
    fig, axes = plt.subplots(1, 3, figsize=(15, 5))

    for idx, condition in enumerate(['Normal', 'Medium', 'High']):
        mask = df['condition'] == condition
        subset = df[mask].sort_values('time_s')

        # Find times when retransmissions occurred
        retrans_times = subset[subset['retransmissions'] > 0]['time_s'].values

        if len(retrans_times) > 1:
            inter_times = np.diff(retrans_times) * 1000
            inter_times = inter_times[inter_times < 1000]
        else:
            inter_times = []

        axes[idx].hist(inter_times, bins=30, color=COLORS[condition], alpha=0.7, edgecolor='black')
        axes[idx].set_xlabel('Time Between Retransmissions (ms)')
        axes[idx].set_ylabel('Frequency')
        axes[idx].set_title(f'{condition} Traffic')
        axes[idx].grid(True, alpha=0.3)

    fig.suptitle('GRAPH 13: Inter-Retransmission Time Distribution\n(Timeout-driven vs Fast-retransmit)', fontsize=14)
    plt.tight_layout()
    save_fig('13_Inter_Retrans_Histogram.png')


