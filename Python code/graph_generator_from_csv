# ============================================
# DATA LOADING
# ============================================

def load_data():
    """Load all three CSV files"""
    print("Loading CSV files...")
    print(f"  Normal: {normal_csv}")
    print(f"  Medium: {medium_csv}")
    print(f"  High: {high_csv}")

    # Check if files exist
    for path in [normal_csv, medium_csv, high_csv]:
        if not os.path.exists(path):
            print(f"  ERROR: File not found - {path}")
            return None, None, None, None

    normal_df = pd.read_csv(normal_csv)
    medium_df = pd.read_csv(medium_csv)
    high_df = pd.read_csv(high_csv)

    # Add condition column
    normal_df['condition'] = 'Normal'
    medium_df['condition'] = 'Medium'
    high_df['condition'] = 'High'

    # Combine for multi-condition plots
    all_df = pd.concat([normal_df, medium_df, high_df], ignore_index=True)

    # Basic info
    print("\n✅ Data loaded successfully:")
    for name, df in [('Normal', normal_df), ('Medium', medium_df), ('High', high_df)]:
        print(f"  {name}: {len(df)} rows")

    return normal_df, medium_df, high_df, all_df


# ============================================
# HELPER FUNCTIONS
# ============================================

def save_fig(filename):
    """Save figure to output directory"""
    if not os.path.exists(OUTPUT_DIR):
        os.makedirs(OUTPUT_DIR)
    filepath = os.path.join(OUTPUT_DIR, filename)
    plt.savefig(filepath, dpi=300, bbox_inches='tight')
    print(f"  ✓ Saved: {filename}")
    plt.close()


def add_condition_scatter(ax, df, x_col, y_col, condition):
    """Add scatter plot for a specific condition"""
    mask = df['condition'] == condition
    data = df.loc[mask, [x_col, y_col]].dropna()
    if len(data) > 0:
        ax.scatter(data[x_col], data[y_col],
                   alpha=0.5, s=15, label=condition, color=COLORS[condition])


