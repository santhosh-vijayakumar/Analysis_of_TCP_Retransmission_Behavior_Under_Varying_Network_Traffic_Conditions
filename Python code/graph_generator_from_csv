def graph_08_cumulative_retransmissions(normal_df, medium_df, high_df):
    """GRAPH 8: Cumulative Retransmissions over Time"""
    print("📊 Generating GRAPH 8: Cumulative Retransmissions")
    fig, ax = plt.subplots(figsize=(12, 6))

    for df, condition in [(normal_df, 'Normal'), (medium_df, 'Medium'), (high_df, 'High')]:
        df_sorted = df.sort_values('time_s')
        cumulative = df_sorted['retransmissions'].cumsum()
        ax.plot(df_sorted['time_s'], cumulative, label=condition, color=COLORS[condition], linewidth=2)

    ax.set_xlabel('Time (seconds)')
    ax.set_ylabel('Cumulative Retransmissions')
    ax.set_title('GRAPH 8: Cumulative Retransmissions over Time\n(When Does System Enter Unrecoverable Region?)')
    ax.legend()
    ax.grid(True, alpha=0.3)
    save_fig('08_Cumulative_Retransmissions.png')


