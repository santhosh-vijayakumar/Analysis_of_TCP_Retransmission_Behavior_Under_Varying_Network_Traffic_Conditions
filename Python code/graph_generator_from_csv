def graph_04_bif_vs_time(normal_df, medium_df, high_df):
    """GRAPH 4: BIF vs Time Series"""
    print("📊 Generating GRAPH 4: BIF vs Time")
    fig, ax = plt.subplots(figsize=(14, 6))

    # Normal (filter outliers)
    mask = normal_df['bytes_in_flight_avg'] < 1e6
    if mask.any():
        ax.plot(normal_df.loc[mask, 'time_s'], normal_df.loc[mask, 'bytes_in_flight_avg'],
                label='Normal', color=COLORS['Normal'], linewidth=1.5, alpha=0.8)

    # Medium
    ax.plot(medium_df['time_s'], medium_df['bytes_in_flight_avg'],
            label='Medium', color=COLORS['Medium'], linewidth=1.5, alpha=0.8)

    # High
    ax.plot(high_df['time_s'], high_df['bytes_in_flight_avg'],
            label='High', color=COLORS['High'], linewidth=1.5, alpha=0.8)

    ax.set_xlabel('Time (seconds)')
    ax.set_ylabel('Bytes In Flight (bytes)')
    ax.set_title('GRAPH 4: BIF vs Time Series\n(Bufferbloat in Medium Traffic)')
    ax.legend()
    ax.set_yscale('log')
    ax.grid(True, alpha=0.3, which='both')

    ax.annotate('Bufferbloat Region\n(BIF ~4.5GB)',
                xy=(320, 4.5e9), xytext=(350, 1e10),
                arrowprops=dict(arrowstyle='->', color=COLORS['Threshold']),
                fontsize=10, color=COLORS['Threshold'])

    save_fig('04_BIF_vs_Time.png')


