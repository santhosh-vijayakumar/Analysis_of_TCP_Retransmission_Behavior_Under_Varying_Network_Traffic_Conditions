def graph_18_goodput_vs_bif_combined(normal_df, medium_df, high_df):
    """GRAPH 18: Goodput vs BIF (log-log, 3 conditions combined)"""
    print("📊 Generating GRAPH 18: Goodput vs BIF Combined (Log-Log)")
    fig, ax = plt.subplots()

    # Filter valid data for each condition
    for df, condition in [(normal_df, 'Normal'), (medium_df, 'Medium'), (high_df, 'High')]:
        mask = (df['goodput_bps'] > 0) & (df['bytes_in_flight_avg'] > 0)
        # Filter extreme BIF values for medium traffic
        if condition == 'Medium':
            mask = mask & (df['bytes_in_flight_avg'] < 1e12)

        x_vals = df.loc[mask, 'bytes_in_flight_avg']
        y_vals = df.loc[mask, 'goodput_bps']

        if len(x_vals) > 0:
            ax.loglog(x_vals, y_vals, 'o', alpha=0.5, markersize=4,
                      label=condition, color=COLORS[condition])

    ax.set_xlabel('Bytes In Flight (bytes) - Log Scale')
    ax.set_ylabel('Goodput (bps) - Log Scale')
    ax.set_title('GRAPH 18: Goodput vs BIF (Log-Log)\n(The Collapse Curve Across Conditions)')
    ax.legend()
    ax.grid(True, alpha=0.3, which='both')
    save_fig('18_Goodput_vs_BIF_Combined.png')


def graph_19_retrans_cost_function(df):
    """GRAPH 19: Retransmission Cost Function"""
    print("📊 Generating GRAPH 19: Retransmission Cost Function")
    fig, ax = plt.subplots()

    for condition in ['Normal', 'Medium', 'High']:
        mask = df['condition'] == condition
        subset = df[mask].copy()

        # Group by retransmission count
        grouped = subset.groupby('retransmissions')['goodput_bps'].mean().reset_index()
        grouped = grouped[grouped['retransmissions'] <= 20]  # Focus on lower range

        if len(grouped) > 0:
            ax.plot(grouped['retransmissions'], grouped['goodput_bps'],
                    'o-', label=condition, color=COLORS[condition], markersize=6)

    ax.set_xlabel('Retransmissions')
    ax.set_ylabel('Average Goodput (bps)')
    ax.set_title('GRAPH 19: Retransmission Cost Function\n(First Retransmissions Cause Disproportionate Damage)')
    ax.legend()
    ax.grid(True, alpha=0.3)
    save_fig('19_Retrans_Cost_Function.png')


def graph_20_rtt_proxy_vs_retransmissions(df):
    """GRAPH 20: RTT Proxy vs Retransmissions"""
    print("📊 Generating GRAPH 20: RTT Proxy vs Retransmissions")
    fig, ax = plt.subplots()

    for condition in ['Normal', 'Medium', 'High']:
        mask = df['condition'] == condition
        subset = df[mask].copy()

        # Use bytes_in_flight as RTT proxy
        throughput_safe = np.where(subset['throughput_bps'] > 0, subset['throughput_bps'] / 8, 1)
        rtt_proxy = np.clip(subset['bytes_in_flight_avg'] / throughput_safe, 0, 1)

        # Filter for plotting
        valid_mask = (rtt_proxy < 1) & (subset['retransmissions'] < 100)

        ax.scatter(rtt_proxy[valid_mask], subset.loc[valid_mask, 'retransmissions'],
                   alpha=0.5, s=15, label=condition, color=COLORS[condition])

    ax.set_xlabel('RTT Proxy (seconds) - from BIF/Throughput')
    ax.set_ylabel('Retransmissions')
    ax.set_title('GRAPH 20: RTT Proxy vs Retransmissions\n(RTT Inflation Precedes Retransmission Spikes)')
    ax.legend()
    ax.grid(True, alpha=0.3)
    save_fig('20_RTT_vs_Retransmissions.png')


